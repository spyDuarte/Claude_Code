# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://plantao:plantao@localhost:5432/plantao_radar

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-very-long-and-random-secret-key-here
JWT_EXPIRES_IN=7d

# ─── AI Classifier ────────────────────────────────────────────────────────────
# Provider: anthropic (default) | openai
AI_CLASSIFIER_PROVIDER=anthropic

# ─── Anthropic (Claude) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
ANTHROPIC_MODEL=claude-opus-4-6

# ─── OpenAI (optional, set AI_CLASSIFIER_PROVIDER=openai to use) ──────────────
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# ─── API Server ───────────────────────────────────────────────────────────────
API_PORT=3001
CORS_ORIGIN=http://localhost:3000

# ─── Web App ──────────────────────────────────────────────────────────────────
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── WhatsApp Provider ────────────────────────────────────────────────────────
# Options: stub | wapi | baileys (extend in whatsapp.module.ts)
WHATSAPP_PROVIDER=stub
WHATSAPP_PROVIDER_BASE_URL=https://your-provider.com
WHATSAPP_PROVIDER_API_KEY=your-provider-api-key

# ─── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Production (Render + Vercel) ─────────────────────────────────────────────
# Render:  DATABASE_URL e REDIS_URL são injetados automaticamente via render.yaml
# Render:  JWT_SECRET é gerado automaticamente (generateValue: true)
# Render:  defina ANTHROPIC_API_KEY (ou OPENAI_API_KEY) e CORS_ORIGIN manualmente no dashboard
#          ex: CORS_ORIGIN=https://plantao-radar.vercel.app
# Vercel:  defina NEXT_PUBLIC_API_URL com a URL pública da API no Render
#          ex: NEXT_PUBLIC_API_URL=https://plantao-radar-api.onrender.com
