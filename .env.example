# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://plantao:plantao@localhost:5432/plantao_radar

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-very-long-and-random-secret-key-here
JWT_EXPIRES_IN=7d

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# ─── API Server ───────────────────────────────────────────────────────────────
API_PORT=3001
CORS_ORIGIN=http://localhost:3000

# ─── Web App ──────────────────────────────────────────────────────────────────
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── WhatsApp Provider ────────────────────────────────────────────────────────
# Options: stub | wapi | baileys (extend in whatsapp.module.ts)
WHATSAPP_PROVIDER=stub
WHATSAPP_PROVIDER_BASE_URL=https://your-provider.com
WHATSAPP_PROVIDER_API_KEY=your-provider-api-key

# ─── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Production (Railway + Vercel) ────────────────────────────────────────────
# Railway: DATABASE_URL e REDIS_URL são preenchidos automaticamente pelos plugins
# Railway: defina JWT_SECRET, OPENAI_API_KEY e NODE_ENV=production manualmente
# Vercel:  defina NEXT_PUBLIC_API_URL com a URL pública da API no Railway
#          ex: NEXT_PUBLIC_API_URL=https://plantao-api.up.railway.app
# Railway: defina CORS_ORIGIN com a URL do frontend no Vercel
#          ex: CORS_ORIGIN=https://plantao-radar.vercel.app
